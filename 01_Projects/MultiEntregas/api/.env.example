# ── Servidor ─────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── Supabase ──────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard/project/TU_PROJECT_REF/settings/api
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXX   # service_role key (NUNCA en frontend)

# ── Email (Resend) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=MultiEntregas <noreply@multientregas.eu>
ADMIN_EMAIL=info@multientregas.eu

# ── IoT API Key (dispositivos GPS/temperatura en tráileres) ──
# Genera un string aleatorio seguro: openssl rand -hex 32
IOT_API_KEY=cambia_esto_por_un_secreto_seguro_32chars

# ── Frontend URL (para CORS) ──────────────────────────────────
FRONTEND_URL=https://multientregas.eu
